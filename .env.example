# Do not commit real secrets in this file.
NEXT_PUBLIC_CONVEX_URL=https://your-convex-deployment.convex.cloud
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SHOW_DEBUG_ERRORS=false
TOKEN_PEPPER=replace-with-long-random-secret

# Optional: only when Vercel build should deploy Convex functions automatically.
# Use a production deploy key for production, never a preview key.
CONVEX_DEPLOY_KEY=replace-with-convex-deploy-key-if-using-ci-deploy
